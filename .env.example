# =============================================================================
# Sun State Digital — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# =============================================================================

# =============================================================================
# DATABASE (PostgreSQL 15)
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ssd_production
POSTGRES_USER=ssd_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_MAX_CONNECTIONS=100
DATABASE_URL=postgresql://ssd_user:CHANGE_ME_strong_password_here@postgres:5432/ssd_production
QUANTUM_DB=ssd_quantum
QUANTUM_DB_URL=postgresql://ssd_user:CHANGE_ME_strong_password_here@postgres:5432/ssd_quantum

# =============================================================================
# REDIS 7
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password_here
REDIS_DB=0
REDIS_URL=redis://:CHANGE_ME_redis_password_here@redis:6379/0
REDIS_SESSION_TTL=86400
REDIS_CACHE_TTL=300

# =============================================================================
# OPENCLAW GATEWAY
# =============================================================================
OPENCLAW_API_KEY=sk-ocl-CHANGE_ME_generate_with_openssl_rand_hex_32
OPENCLAW_WEBHOOK_SECRET=whsec-CHANGE_ME_generate_with_openssl_rand_hex_32
OPENCLAW_PORT=3000
OPENCLAW_MAX_REQUESTS_PER_MINUTE=100

# =============================================================================
# QUANTUM BACKEND API
# =============================================================================
QUANTUM_API_PORT=8000
QUANTUM_API_WORKERS=4
QUANTUM_API_KEY=sk-qnt-CHANGE_ME_generate_with_openssl_rand_hex_32

# =============================================================================
# AWS CONFIGURATION
# =============================================================================
AWS_REGION=ap-southeast-2
AWS_ACCOUNT_ID=123456789012
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# Domain & SSL
DOMAIN=ssd.cloud
EMAIL=josh@sunstatedigital.com.au
SSL_PROVIDER=letsencrypt

# Database
POSTGRES_USER=ssdadmin
POSTGRES_PASSWORD=secure_random_password_here
POSTGRES_DB=ssd_production
DB_PORT=5432

# Redis
REDIS_PASSWORD=secure_redis_password_here
REDIS_PORT=6379

# OpenClaw Gateway
GATEWAY_PORT=18789
GATEWAY_TOKEN=generate_secure_token_here
GATEWAY_SECRET=generate_secure_secret_here

# Quantum API
API_PORT=3000
API_JWT_SECRET=jwt_secret_key_here
API_ENCRYPTION_KEY=encryption_key_here

# N8n Workflow Engine
N8N_PORT=5678
N8N_DB_TYPE=postgresdb
N8N_ENCRYPTION_KEY=n8n_encryption_key_here

# Blog Frontend
BLOG_PORT=80
BLOG_DOMAIN=blog.ssd.cloud

# S3 Buckets
S3_BLOG_BUCKET=ssd-blog-production
S3_BACKUPS_BUCKET=ssd-backups-production
S3_ASSETS_BUCKET=ssd-assets-production
S3_REGION=ap-southeast-2

# CloudFront
CLOUDFRONT_DISTRIBUTION_ID=E1234ABCD5678

# Backup Configuration
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2am UTC

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
DATADOG_API_KEY=optional_datadog_key
SENTRY_DSN=optional_sentry_dsn

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@sunstatedigital.com.au
SMTP_PASSWORD=smtp_app_password
SMTP_FROM=noreply@sunstatedigital.com.au

# Stripe (Payment Processing)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret
STRIPE_PUBLIC_KEY=pk_live_your_stripe_public
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Auth & Security
JWT_EXPIRY=7d
SESSION_TIMEOUT=3600
SESSION_SECURE=true
SESSION_HTTPONLY=true
CORS_ORIGINS=https://ssd.cloud,https://dashboard.ssd.cloud

# Terraform
TERRAFORM_BUCKET=ssd-terraform-state
TERRAFORM_DYNAMODB_TABLE=ssd-terraform-locks

# Environment
NODE_ENV=production
DEBUG=false
LOG_LEVEL=info
