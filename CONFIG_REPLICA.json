      "port": 9090,
      "exposed": false,
      "scrape_interval": "15s",
      "retention": "15d",
      "resources": {
        "memory_limit": "256m",
        "cpu_limit": 0.25
      },
      "restart_policy": "unless-stopped",
      "volumes": ["ssd-prometheus-data:/prometheus"],
      "networks": ["ssd-network", "monitoring-network"],
      "scrape_targets": [
        "openclaw-gateway:3000",
        "quantum-api:8000",
        "postgres:5432",
        "redis:6379",
        "nginx:80"
      ]
    }
