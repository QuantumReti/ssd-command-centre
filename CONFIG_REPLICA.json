    "postgres": {
      "container_name": "postgres",
      "image": "postgres:15.5-alpine",
      "version": "15.5",
      "port": 5432,
      "exposed": false,
      "health_check": {
        "command": "pg_isready -U ssd_user -d ssd_production",
        "interval": "30s",
        "timeout": "10s",
        "retries": 5
      },
      "resources": {
        "memory_limit": "512m",
        "memory_reserve": "256m",
        "cpu_limit": 0.5
      },
      "restart_policy": "unless-stopped",
      "volumes": [
        "ssd-postgres-data:/var/lib/postgresql/data"
      ],
      "config_overrides": {
        "max_connections": 100,
        "shared_buffers": "128MB",
        "effective_cache_size": "512MB",
        "work_mem": "4MB",
        "checkpoint_completion_target": 0.9,
        "wal_buffers": "16MB"
      },
      "databases": [
        "ssd_production",
        "ssd_quantum",
        "quantum_buyers"
      ],
      "networks": ["ssd-network"]
    },
    "redis": {
      "container_name": "redis",
      "image": "redis:7.2.3-alpine",
      "version": "7.2.3",
      "port": 6379,
      "exposed": false,
      "health_check": {
        "command": "redis-cli ping",
        "interval": "30s",
        "timeout": "10s",
        "retries": 3
      },
      "resources": {
        "memory_limit": "256m",
        "memory_reserve": "128m",
        "cpu_limit": 0.25
      },
      "restart_policy": "unless-stopped",
      "volumes": [
        "ssd-redis-data:/data"
      ],
      "config": {
        "maxmemory": "200mb",
        "maxmemory_policy": "allkeys-lru",
        "appendonly": true,
        "appendfsync": "everysec",
        "requirepass": "[REDACTED]"
      },
      "networks": ["ssd-network"]
    },
    "nginx": {
      "container_name": "nginx",
      "image": "nginx:1.25.3-alpine",
      "version": "1.25.3",
      "ports": [80, 443],
      "ssl_provider": "letsencrypt",
      "ssl_domain": "*.ssd.cloud",
      "virtual_hosts": [
        {"host": "ssd.cloud", "upstream": "openclaw-gateway:3000"},
        {"host": "api.ssd.cloud", "upstream": "openclaw-gateway:3000"},
        {"host": "openclaw.ssd.cloud", "upstream": "openclaw-gateway:3000"},
        {"host": "quantum.ssd.cloud", "upstream": "quantum-api:8000"},
        {"host": "blog.ssd.cloud", "upstream": "blog-frontend:3001"},
        {"host": "monitor.ssd.cloud", "upstream": "grafana:3000"}
      ],
      "features": [
        "ssl_termination",
        "gzip_compression",
        "rate_limiting",
        "security_headers",
        "websocket_proxy",
        "http2"
      ],
      "restart_policy": "unless-stopped",
      "volumes": [
        "./nginx.conf:/etc/nginx/nginx.conf:ro",
        "/etc/letsencrypt:/etc/letsencrypt:ro",
        "ssd-nginx-logs:/var/log/nginx"
      ],
      "networks": ["ssd-network"]
    },
    "grafana": {
      "container_name": "grafana",
      "image": "grafana/grafana:10.2.2",
      "version": "10.2.2",
      "port": 3000,
      "host_port": 3002,
      "exposed_via_nginx": "monitor.ssd.cloud",
      "admin_user": "admin",
      "admin_password": "[REDACTED - see .env GRAFANA_ADMIN_PASSWORD]",
      "resources": {
        "memory_limit": "256m",
        "cpu_limit": 0.25
